{
  "openapi": "3.1.0",
  "info": { "title": "Fixture REST API", "version": "1.0" },
  "paths": {
    "/{apiKey}/foo/create": {
      "post": {
        "operationId": "create-foo",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": { "name": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "id": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    "/v3/{apiKey}/getBar": {
      "get": {
        "operationId": "getBar-v3",
        "parameters": [
          {
            "name": "apiKey",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "owner",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "tags[]",
            "in": "query",
            "schema": { "type": "array", "items": { "type": "string" } }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
