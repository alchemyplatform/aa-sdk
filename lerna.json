{
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "version": "5.0.3",
  "npmClient": "pnpm",
  "packages": [
    "packages/aa-infra",
    "packages/common",
    "packages/smart-accounts",
    "packages/wallet-apis"
  ],
  "granularPathspec": false,
  "command": {
    "version": {
      "message": "chore(release): publish %s [skip ci]",
      "forcePublish": true,
      "conventionalCommits": true
    },
    "publish": {
      "distTag": "latest",
      "access": "public"
    }
  }
}
