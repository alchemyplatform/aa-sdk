{
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build", "generate"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "cache": true
    },
    "generate": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/src/plugins", "{projectRoot}/src/generated"],
      "cache": false
    },
    "prepare": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": false
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [],
    "production": ["default"]
  }
}
